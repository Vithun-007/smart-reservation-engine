generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {

  id          String       @id @default(cuid())

  name        String

  price       Int

  inventories Inventory[]

}

model Warehouse {

  id          String       @id @default(cuid())

  name        String

  city        String

  inventories Inventory[]

}

model Inventory {

  id              String        @id @default(cuid())

  productId       String

  warehouseId     String

  totalStock      Int

  reservedStock   Int           @default(0)

  product         Product       @relation(
    fields: [productId],
    references: [id]
  )

  warehouse       Warehouse    @relation(
    fields: [warehouseId],
    references: [id]
  )

  reservations    Reservation[]

}

model Reservation {

  id                String      @id @default(cuid())

  inventoryId       String

  quantity          Int

  status            ReservationStatus

  expiresAt         DateTime

  createdAt         DateTime    @default(now())

  idempotencyKey    String?     @unique

  inventory         Inventory   @relation(
    fields: [inventoryId],
    references: [id]
  )

}

enum ReservationStatus {

  PENDING

  CONFIRMED

  RELEASED

}